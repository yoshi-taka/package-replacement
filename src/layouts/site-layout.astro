---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Own the behavior you depend on." } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        --bg: #f5f0e8;
        --surface: rgba(255, 252, 247, 0.92);
        --surface-strong: #fffaf2;
        --ink: #1f1d19;
        --muted: #6b6458;
        --line: rgba(31, 29, 25, 0.14);
        --accent: #bf5a36;
        --accent-soft: rgba(191, 90, 54, 0.12);
        --shadow: 0 20px 60px rgba(49, 38, 18, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        background:
          radial-gradient(circle at top left, rgba(191, 90, 54, 0.18), transparent 28%),
          radial-gradient(circle at top right, rgba(116, 127, 95, 0.18), transparent 22%),
          linear-gradient(180deg, #f8f3ec 0%, #f4ede3 100%);
        color: var(--ink);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        width: min(1120px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 32px 0 64px;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(8px);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.45);
        color: var(--muted);
        font-size: 0.82rem;
        letter-spacing: 0.04em;
      }

      .button {
        appearance: none;
        border: 1px solid var(--line);
        background: var(--surface-strong);
        color: var(--ink);
        border-radius: 999px;
        padding: 12px 18px;
        font: inherit;
        cursor: pointer;
      }

      .button.primary {
        background: var(--ink);
        border-color: var(--ink);
        color: #fff8f1;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .grid {
        display: grid;
        gap: 24px;
      }

      .muted {
        color: var(--muted);
      }

      code,
      pre {
        font-family: "SFMono-Regular", "Menlo", "Monaco", "Consolas", monospace;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <slot />
    </div>
  </body>
</html>
